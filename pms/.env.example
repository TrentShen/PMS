# PMS 环境变量模板
# 使用方式：cp .env.example .env 后，把各项改为本地/生产实际值

# --- 应用 ---
APP_ENV=local
APP_PORT=8000
# 生产必须改为强随机串（openssl rand -hex 32）
APP_SECRET=change-me-in-production

# --- MySQL（dev 环境用 3307 避让本机 MySQL） ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=pms
MYSQL_PASSWORD=pms_password
MYSQL_DATABASE=pms

# --- Redis（dev 环境用 6380 避让本机其他 Redis） ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=

# --- 企业微信（找企微管理员申请自建应用后填入） ---
WECOM_CORPID=
WECOM_AGENTID=
# 自建应用 secret；PMS 用此 secret 即可调用通讯录接口和人事助手接口
WECOM_SECRET=
# 通讯录同步 secret（当前未使用，保留用于兼容旧配置）
WECOM_CONTACT_SECRET=
# 生产改为 https://pms.company.com/auth/callback
WECOM_REDIRECT_URI=http://localhost:5173/api/v1/auth/callback

# --- 前端地址（CORS） ---
FRONTEND_ORIGIN=http://localhost:5173
